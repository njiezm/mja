APP_NAME="Madin'Jeunes Ambition"
APP_ENV=production
APP_KEY=base64:REMPLACER_PAR_UNE_CLE_GENEREE
APP_DEBUG=false
APP_URL=https://www.mja-martinique.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

# ─── Base de données (MySQL sur hébergement mutualisé) ────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=NOM_BDD_DONNE_PAR_HEBERGEUR
DB_USERNAME=USER_BDD_DONNE_PAR_HEBERGEUR
DB_PASSWORD=MOT_DE_PASSE_BDD

# ─── Sessions ─────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Cache / Queue ────────────────────────────────────────────────
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ─── Mail (configurer avec le mail de l'association) ─────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.mja-martinique.com
MAIL_PORT=587
MAIL_USERNAME=contact@mja-martinique.com
MAIL_PASSWORD=MOT_DE_PASSE_MAIL
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contact@mja-martinique.com"
MAIL_FROM_NAME="Madin'Jeunes Ambition"
